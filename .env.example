# Copy to `.env` and fill in. Every variable below is read by the app — no hidden defaults in code.
# API keys: set the ones for the backend you use; others can be left empty.

# --- Synthesis backend: gemini | groq | openai ---
SYNTHESIS_BACKEND=gemini

# --- API keys (leave unused ones empty) ---
GOOGLE_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# --- Gemini & Whisper (always set; used by ADK agents and Whisper) ---
GEMINI_MODEL=gemini-2.5-flash-lite
WHISPER_MODEL=tiny

# --- Feeds & transcription ---
PODCAST_RSS_URLS=https://api.substack.com/feed/podcast/69345.rss,https://feeds.transistor.fm/acquired,https://feeds.megaphone.fm/darknetdiaries
TRANSCRIBE_MAX_SECONDS=300
BUILD_SAMPLE_TRANSCRIBE_SECONDS=90

# --- Orchestration ---
ADK_TOOLS_ONLY=0
ORCHESTRATOR_MIN_SUCCESS=2
PODCAST_RSS_RETRIES=3
# First backoff delay (seconds) for RSS fetch/parse retries; podcast hosts often need 2–30s to recover.
PODCAST_RSS_RETRY_BASE_DELAY_SEC=2.5
PODCAST_TRANSCRIBE_RETRIES=3

# --- Paths (relative paths are under the project root) ---
CHECKPOINT_DIR=.checkpoints
DEAD_LETTER_PATH=dead_letter.jsonl
BRIEFING_OUTPUT_PATH=intelligence_briefing.md

# --- OpenAI-compatible (Groq / OpenAI / OpenRouter) ---
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# --- Optional LLM throttle before synthesis (0 = off) ---
LLM_MIN_INTERVAL_SEC=0
LLM_TOKEN_BUCKET_REFILL_PER_SEC=
LLM_TOKEN_BUCKET_CAPACITY=1
